# MCP Security Gateway – environment variables
# Copy this file to .env and fill in real values before running locally.

# ── JWT Authentication ────────────────────────────────────────────────────────

# For HS256 (default): set this to a long random secret (≥ 32 chars).
#   Generate one with:  python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_to_a_long_random_secret

# Algorithm used to sign the JWT. Common values:
#   HS256  – HMAC-SHA256 (shared secret, local dev)
#   RS256  – RSA-SHA256   (set JWT_SECRET to path of PEM public-key file)
#   ES256  – ECDSA-P256   (set JWT_SECRET to path of PEM public-key file)
JWT_ALGORITHM=HS256

# Audience claim ("aud") to validate.
# Leave empty to skip audience validation (acceptable for local dev).
JWT_AUDIENCE=

# Custom roles claim key inside the JWT payload.
# Must match whatever your identity provider / token minter uses.
JWT_ROLES_CLAIM=https://mcp-gateway/roles

# ── General Gateway Settings ──────────────────────────────────────────────────
UPSTREAM_SERVERS_FILE=./config/upstreams.json
TOOL_POLICY_FILE=./config/tool_policies.json
DATABASE_PATH=./data/gateway.db
SERVER_NAME=mcp-security-gateway
MCP_PROTOCOL_VERSION=2025-06-18
